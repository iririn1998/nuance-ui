{
  "name": "nuance-ui",
  "version": "0.0.1",
  "description": "A neumorphism-inspired UI component library built on top of Mantine",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:storybook": "vitest run --config vitest.storybook.config.mts",
    "test:storybook:watch": "vitest --config vitest.storybook.config.mts",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt -c node_modules/@nuance-ui/config/src/oxfmt/base.json src",
    "fmt:check": "oxfmt -c node_modules/@nuance-ui/config/src/oxfmt/base.json --check src",
    "lint": "NODE_OPTIONS='--experimental-strip-types --no-warnings' oxlint src",
    "lint:fix": "NODE_OPTIONS='--experimental-strip-types --no-warnings' oxlint src --fix"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "@mantine/core": "^7.0.0",
    "@mantine/hooks": "^7.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@mantine/core": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@nuance-ui/config": "workspace:*",
    "@storybook/experimental-addon-test": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test": "^8.6.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/browser": "^2.1.0",
    "happy-dom": "^20.7.0",
    "jsdom": "^25.0.0",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "playwright": "^1.49.0",
    "postcss": "^8.4.0",
    "postcss-preset-mantine": "^1.17.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.6.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  }
}