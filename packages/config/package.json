{
  "name": "@nuance-ui/config",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared configurations for nuance-ui monorepo",
  "scripts": {
    "fmt": "oxfmt -c src/oxfmt/base.json src",
    "fmt:check": "oxfmt -c src/oxfmt/base.json --check src"
  },
  "exports": {
    "./oxlint": {
      "import": "./src/oxlint/index.ts",
      "require": "./src/oxlint/index.ts"
    },
    "./oxfmt": "./src/oxfmt/base.json",
    "./storybook/main": "./src/storybook/main.ts",
    "./storybook/preview": "./src/storybook/preview.tsx",
    "./storybook/vitest-plugin": {
      "types": "./src/storybook/vitest-plugin.ts",
      "default": "./src/storybook/vitest-plugin.js"
    },
    "./vitest": {
      "types": "./src/vitest/index.d.ts",
      "default": "./src/vitest/index.js"
    }
  },
  "devDependencies": {
    "@mantine/core": "catalog:",
    "@storybook/addon-essentials": "catalog:",
    "@storybook/addon-interactions": "catalog:",
    "@storybook/addon-links": "catalog:",
    "@storybook/experimental-addon-test": "catalog:",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@types/react": "catalog:",
    "happy-dom": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
